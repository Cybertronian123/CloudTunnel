<UserControl
    x:Class="CloudTunnel.Controls.StatusBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        x:Name="BadgeBorder"
        Background="#44EF4444"
        CornerRadius="10"
        Padding="10,2"
        Height="24">

        <StackPanel
            Orientation="Horizontal"
            Spacing="6">

            <Ellipse
                x:Name="StatusDot"
                Width="8"
                Height="8"
                Fill="#EF4444"
                VerticalAlignment="Center"/>

            <TextBlock
                x:Name="StatusText"
                Text="Stopped"
                FontSize="10"
                VerticalAlignment="Center"/>

        </StackPanel>

    </Border>

</UserControl>